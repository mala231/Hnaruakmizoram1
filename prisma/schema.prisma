datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Employer {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  email        String    @unique
  phone        String
  address      String
  logoUrl      String    @map("logo_url")
  isVerified   Boolean   @default(false) @map("is_verified")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  jobPosts     JobPost[]
  payments     Payment[]

  @@map("employers")
}

model JobPost {
  id               String    @id @default(uuid())
  employerId       String    @map("employer_id")
  employer         Employer  @relation(fields: [employerId], references: [id])
  title            String
  shortDescription String    @map("short_description")
  description      String    @db.Text
  categoryId       Int       @map("category_id")
  category         Category  @relation(fields: [categoryId], references: [id])
  locationId       Int       @map("location_id")
  location         Location  @relation(fields: [locationId], references: [id])
  address          String
  deadline         DateTime
  interviewTime    String    @map("interview_time")
  status           String    @default("draft") // draft, live, expired, deleted
  durationDays     Int       @map("duration_days")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  payments         Payment[]
  reports          Report[]

  @@map("job_posts")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  jobPosts  JobPost[]

  @@map("categories")
}

model Location {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  jobPosts  JobPost[]

  @@map("locations")
}

model Payment {
  id                String   @id @default(uuid())
  employerId        String   @map("employer_id")
  employer          Employer @relation(fields: [employerId], references: [id])
  jobPostId         String   @map("job_post_id")
  jobPost           JobPost  @relation(fields: [jobPostId], references: [id])
  razorpayOrderId   String   @unique @map("razorpay_order_id")
  razorpayPaymentId String?  @unique @map("razorpay_payment_id")
  razorpaySignature String?  @map("razorpay_signature")
  amount            Decimal  @db.Decimal(10, 2)
  durationDays      Int      @map("duration_days")
  status            String   @default("pending") // pending, confirmed, failed
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

model Report {
  id        Int      @id @default(autoincrement())
  jobPostId String   @map("job_post_id")
  jobPost   JobPost  @relation(fields: [jobPostId], references: [id])
  reason    String
  details   String?  @db.Text
  status    String   @default("pending") // pending, reviewed, dismissed
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model TickerItem {
  id        Int      @id @default(autoincrement())
  text      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ticker_items")
}

model Advertisement {
  id        Int      @id @default(autoincrement())
  imageUrl  String   @map("image_url")
  targetUrl String   @map("target_url")
  position  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("advertisements")
}
